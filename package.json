{
  "name": "wiki-cli",
  "version": "0.1.0",
  "description": "A command-line tool to fetch Wikipedia articles and convert them to Markdown format",
  "scripts": {
    "prepare": "husky install",
    "lint": "bash lint.sh",
    "lint:shellcheck": "shellcheck wiki",
    "lint:markdown": "prettier --check README.md",
    "format": "prettier --write README.md",
    "format:check": "prettier --check README.md",
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "wiki": [
      "shellcheck"
    ],
    "*.md": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "keywords": [
    "wikipedia",
    "markdown",
    "cli",
    "bash"
  ],
  "author": "",
  "license": "MIT"
}
